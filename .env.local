# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_secret

# Prisma (database)
DATABASE_URL="file:D:/Hackathons/lovhack/drygate/dev.db"

# Optional: enable AI-enhanced remediation (Claude)
# ANTHROPIC_API_KEY=your_anthropic_key

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sandbox n8n — points to the persistent n8n container.
# Start it once with: docker compose pull && docker compose up -d
SANDBOX_N8N_URL=http://localhost:5678
# Optional: n8n public API key (Settings → API) — helps n8n 2.x public routes (/api/v1/.../execute).
# Leave blank to use HTTP Basic only (drygate / drygate-sandbox-pw).
# SANDBOX_N8N_API_KEY=
# Optional: pin image tag for ephemeral Docker sandbox (default n8nio/n8n:latest).
# SANDBOX_N8N_IMAGE=n8nio/n8n:latest

