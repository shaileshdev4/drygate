# Copy to .env.local and adjust values.

# ── App ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL - e.g. Supabase) ───
# Transaction pooler :6543 for the running app (append ?pgbouncer=true if you see prepared statement errors)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
# Session/direct :5432 for prisma db push (required for advisory locks)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# ── Sandbox (persistent n8n - recommended) ──
SANDBOX_N8N_URL=http://localhost:5678
# Optional: n8n Settings → API (helps some public API paths on newer n8n)
# SANDBOX_N8N_API_KEY=

# Ephemeral Docker-per-request sandbox is not enabled in this build - leave SANDBOX_N8N_URL set.

# ── Optional guardrails ───────────────────────
# DRYGATE_INPUT_FUZZ=true
# DRYGATE_EGRESS_ALLOWLIST=api.stripe.com
# DRYGATE_PRODUCTION_CREDENTIAL_ALLOWLIST=Stripe Production

# Clerk is not used by the UI (demo-user mode). Keys can be omitted.
