          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Seed Test Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "cond-001",
              "leftValue": "={{ $json.email }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Has Valid Email",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const lead = item.json;\n  let score = 0;\n\n  // Budget scoring\n  if (lead.budget >= 50000) score += 40;\n  else if (lead.budget >= 10000) score += 25;\n  else if (lead.budget >= 1000) score += 10;\n\n  // Source scoring\n  const highValue = ['referral', 'enterprise', 'partner'];\n  if (highValue.includes(lead.source)) score += 30;\n  else if (lead.source === 'organic') score += 15;\n\n  // Company size scoring — throws TypeError if companySize is undefined\n  // Static analysis misses this. Sandbox catches it. That's the point.\n  const bonus = lead.companySize.employees > 100 ? 20 : 10;\n  score += bonus;\n\n  const tier = score >= 70 ? 'hot' : score >= 40 ? 'warm' : 'cold';\n\n  results.push({\n    json: {\n      ...lead,\n      leadScore: score,\n      tier,\n      scoredAt: new Date().toISOString(),\n      assignedRep: score >= 70 ? 'senior-team' : 'standard-team'\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Score Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 220]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "f1", "name": "status", "value": "rejected", "type": "string" },
            { "id": "f2", "name": "reason", "value": "Missing or invalid email", "type": "string" },
            { "id": "f3", "name": "timestamp", "value": "={{ new Date().toISOString() }}", "type": "string" }
          ]
        },
        "options": {}
