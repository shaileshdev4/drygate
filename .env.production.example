# ── App ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.railway.app

# ── Database (Supabase) ──────────────────────
# Transaction pooler :6543 → app runtime
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
# Session pooler :5432 → prisma db push / migrations (transaction pooler alone can hang on db push)
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Clerk (optional — app runs demo-user mode without keys) ─
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# ── Sandbox (n8n on Railway internal network) ─
SANDBOX_N8N_URL=http://drygate-n8n-sandbox.railway.internal:5678

# ── Optional guardrails ───────────────────────
# DRYGATE_INPUT_FUZZ=true
# DRYGATE_EGRESS_ALLOWLIST=api.stripe.com,api.sendgrid.com
# DRYGATE_PRODUCTION_CREDENTIAL_ALLOWLIST=Stripe Production,SendGrid Main
