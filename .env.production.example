# ── App ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.railway.app

# ── Database (Supabase) ──────────────────────
# Railway uses prisma/schema.production.prisma (postgresql provider) via railway.toml
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Clerk Auth ───────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── Sandbox (n8n on Railway internal network) ─
SANDBOX_N8N_URL=http://drygate-n8n-sandbox.railway.internal:5678

# ── Optional guardrails ───────────────────────
# DRYGATE_INPUT_FUZZ=true
# DRYGATE_EGRESS_ALLOWLIST=api.stripe.com,api.sendgrid.com
# DRYGATE_PRODUCTION_CREDENTIAL_ALLOWLIST=Stripe Production,SendGrid Main
