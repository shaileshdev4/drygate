generator client {
  provider = "prisma-client-js"
}

// DATABASE_URL: use the transaction pooler (e.g. Supabase :6543) with ?pgbouncer=true
// so Prisma disables prepared statements — otherwise Postgres can error with:
//   prepared statement "s0" already exists (42P05)
// DIRECT_URL: direct or session pooler for migrations / db push (no pgbouncer flag).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Verification {
  id                 String   @id @default(uuid())
  shareToken         String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  userId             String?
  workflowName       String
  nodeCount          Int
  triggerType        String?
  status             String   @default("pending")
  readinessScore     Int?
  scoreband          String?
  simulationCoverage Float?
  workflowJson       String?
  staticReportJson     String?
  complexityReportJson String?
  runtimeReportJson  String?
  remediationJson    String?
  pipelineError      String?
}


